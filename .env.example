# Pro-Online (pronline) — copy to .env and adjust
#   cp .env.example .env
#
# Hostinger / Git deploy: .env is usually NOT on the server (gitignored).
# Set variables in hPanel → Websites → your site → Advanced → Environment variables.
# Required on first deploy: ADMIN_PASSWORD (and NODE_ENV=production, SESSION_SECRET).

# ——— Required for first boot (creates admin user if missing) ———
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ——— Server ———
PORT=3000
NODE_ENV=development
SESSION_SECRET=change_this_to_a_long_random_string

# ——— Domains (subdomain company sites: biz.yourdomain.com) ———
BASE_DOMAIN=
PUBLIC_SCHEME=https

# ——— SQLite (default: data/pronline.sqlite) ———
# SQLITE_PATH=data/pronline.sqlite

# ——— Sessions (default: data/sessions.db) ———
# SESSION_DIR=data
# SESSION_DB_PATH=data/sessions.db

# ——— Public contact (footer, company pages) ———
CALL_CENTER_PHONE=
PRO_ONLINE_EMAIL=
PRO_ONLINE_ADDRESS=

# Legacy aliases (optional; used if PRO_ONLINE_* not set)
# NETRA_EMAIL=
# NETRA_ADDRESS=

# ——— Seed script only ———
# DEMO_COMPANY_SUBDOMAIN=demo
