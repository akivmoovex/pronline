<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= category.name %> | Directory | Pro-Online</title>
    <link rel="stylesheet" href="/styles.css?v=20260320b" />
  </head>
  <body>
    <%- include('partials/site_header') %>

    <div class="container">
      <div style="margin:18px 0;">
        <div class="section-title" style="margin-top:0;"><%= category.name %></div>
        <div class="muted" style="line-height:1.6;">
          One-page company sites in this category. Each company has a unique subdomain.
        </div>
      </div>

      <div class="hero-grid" style="grid-template-columns: 0.9fr 1.1fr;">
        <div class="card">
          <div style="font-weight:900;margin-bottom:12px;">All Categories</div>
          <div class="list">
            <% categories.forEach(function(cat) { %>
              <a
                href="/category/<%= cat.slug %>"
                class="btn"
                style="justify-content:flex-start;width:100%;<%= category.slug === cat.slug ? 'border-color:var(--pro-orange);background:rgba(232,90,27,0.08);' : '' %>"
              >
                <%= cat.name %>
              </a>
            <% }) %>
          </div>
        </div>

        <div class="list">
          <% if (companies.length === 0) { %>
            <div class="card">No companies found.</div>
          <% } else { %>
            <% companies.forEach(function(c) { %>
              <a class="card" href="<%= buildCompanyUrl({ baseDomain: baseDomain, subdomain: c.subdomain }) %>" target="_blank" rel="noreferrer">
                <div class="row-between">
                  <div style="font-weight:900;font-size:16px;"><%= c.name %></div>
                  <div class="muted" style="font-size:12px;">@<%= c.subdomain %></div>
                </div>
                <% if (c.headline) { %>
                  <div class="muted" style="margin-top:6px;line-height:1.5;"><%= c.headline %></div>
                <% } %>
              </a>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <%- include('partials/site_footer') %>
    <script src="/scripts.js"></script>
  </body>
</html>

