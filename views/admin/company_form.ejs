<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= company ? 'Edit' : 'New' %> Company | Pro-Online Admin</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="container" style="padding: 22px 0;">
      <div class="nav" style="padding-top:0;">
        <div class="brand">
          <div class="logo" aria-hidden="true"></div>
          <div style="font-weight:900;"><%= company ? 'Edit Company' : 'New Company' %></div>
        </div>
        <div class="nav-links">
          <a class="btn" href="/admin/companies">Back</a>
        </div>
      </div>

      <div class="card" style="max-width: 900px; margin-top:16px;">
        <form
          method="post"
          action="<%= company ? '/admin/companies/' + company.id : '/admin/companies' %>"
          class="form"
        >
          <div class="hero-grid" style="grid-template-columns: 1fr 1fr;">
            <div>
              <label for="name">Company Name</label>
              <input id="name" name="name" value="<%= company ? company.name : '' %>" required />
            </div>
            <div>
              <label for="subdomain">Subdomain</label>
              <input id="subdomain" name="subdomain" value="<%= company ? company.subdomain : '' %>" required />
              <div class="muted" style="margin-top:6px;font-size:12px;line-height:1.5;">
                Example: <span class="kbd">mybiz</span> (renders at <span class="kbd">mybiz.<%= baseDomain || 'example.com' %></span>)
              </div>
            </div>
          </div>

          <div>
            <label for="category_id">Category</label>
            <select id="category_id" name="category_id">
              <option value="">Uncategorized</option>
              <% categories.forEach(function(cat) { %>
                <option value="<%= cat.id %>" <%= company && company.category_id === cat.id ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="headline">Headline</label>
            <input id="headline" name="headline" value="<%= company ? company.headline : '' %>" />
          </div>

          <div>
            <label for="about">About</label>
            <textarea id="about" name="about"><%= company ? company.about : '' %></textarea>
          </div>

          <div>
            <label for="services">Services (one per line)</label>
            <textarea id="services" name="services"><%= company ? company.services : '' %></textarea>
          </div>

          <div class="hero-grid" style="grid-template-columns: 1fr 1fr;">
            <div>
              <label for="phone">Phone</label>
              <input id="phone" name="phone" value="<%= company ? company.phone : '' %>" />
            </div>
            <div>
              <label for="email">Email</label>
              <input id="email" name="email" type="email" value="<%= company ? company.email : '' %>" />
            </div>
          </div>

          <div>
            <label for="location">Location</label>
            <input id="location" name="location" value="<%= company ? company.location : '' %>" />
          </div>

          <div class="hero-grid" style="grid-template-columns: 1fr 1fr;">
            <div>
              <label for="featured_cta_label">CTA Label</label>
              <input id="featured_cta_label" name="featured_cta_label" value="<%= company ? company.featured_cta_label : 'Call us' %>" />
            </div>
            <div>
              <label for="featured_cta_phone">CTA Phone</label>
              <input id="featured_cta_phone" name="featured_cta_phone" value="<%= company ? company.featured_cta_phone : '' %>" />
            </div>
          </div>

          <button class="btn btn-primary" type="submit" style="margin-top:10px;">
            Save
          </button>
        </form>
      </div>
    </div>
  </body>
</html>

